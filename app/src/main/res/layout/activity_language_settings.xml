<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/colorBackground">

  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:background="@color/colorPrimary" android:orientation="horizontal"
      android:gravity="center_vertical" android:padding="12dp">
    <ImageButton android:id="@+id/btnBack" android:layout_width="36dp" android:layout_height="36dp"
        android:src="@android:drawable/ic_menu_revert"
        android:background="?attr/selectableItemBackgroundBorderless" android:layout_marginEnd="8dp"/>
    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:text="@string/language_settings" android:textColor="@color/white"
        android:textSize="18sp" android:textStyle="bold"/>
  </LinearLayout>

  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:padding="24dp" android:gravity="center">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🌐" android:textSize="52sp" android:layout_marginBottom="16dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/choose_language" android:textColor="@color/colorTextPrimary"
        android:textSize="17sp" android:textStyle="bold" android:gravity="center"
        android:layout_marginBottom="6dp"/>
    <TextView android:id="@+id/tvCurrent" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="Current: English"
        android:textColor="@color/colorTextSecondary" android:textSize="13sp"
        android:layout_marginBottom="32dp"/>

    <!-- English -->
    <androidx.cardview.widget.CardView android:layout_width="match_parent"
        android:layout_height="wrap_content" app:cardCornerRadius="12dp"
        app:cardElevation="3dp" android:layout_marginBottom="14dp">
      <LinearLayout android:id="@+id/btnEnglish" android:layout_width="match_parent"
          android:layout_height="72dp" android:orientation="horizontal"
          android:gravity="center_vertical" android:padding="16dp"
          android:background="@color/colorSurface">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🇬🇧" android:textSize="30sp" android:layout_marginEnd="14dp"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="@string/lang_english" android:textColor="@color/colorTextPrimary"
              android:textSize="16sp" android:textStyle="bold"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="@string/lang_switch_en" android:textColor="@color/colorTextSecondary"
              android:textSize="12sp"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="→" android:textColor="@color/colorPrimary"
            android:textSize="20sp" android:textStyle="bold"/>
      </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Kannada -->
    <androidx.cardview.widget.CardView android:layout_width="match_parent"
        android:layout_height="wrap_content" app:cardCornerRadius="12dp" app:cardElevation="3dp">
      <LinearLayout android:id="@+id/btnKannada" android:layout_width="match_parent"
          android:layout_height="72dp" android:orientation="horizontal"
          android:gravity="center_vertical" android:padding="16dp"
          android:background="@color/colorSurface">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🇮🇳" android:textSize="30sp" android:layout_marginEnd="14dp"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="@string/lang_kannada" android:textColor="@color/colorTextPrimary"
              android:textSize="16sp" android:textStyle="bold"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="@string/lang_switch_kn" android:textColor="@color/colorTextSecondary"
              android:textSize="12sp"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="→" android:textColor="@color/colorAccent"
            android:textSize="20sp" android:textStyle="bold"/>
      </LinearLayout>
    </androidx.cardview.widget.CardView>

  </LinearLayout>
</LinearLayout>